# ──────────────────────────────────────────────
# PteroStore API Server — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/pterostore

# Security
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars

# CORS — comma-separated allowed origins, or * to allow all
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# SMTP Email (for OTP verification)
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password

# Admin seed (on first run)
ADMIN_EMAIL=admin@pterostore.com
ADMIN_PASSWORD=change_this_strong_password
ADMIN_USERNAME=admin
