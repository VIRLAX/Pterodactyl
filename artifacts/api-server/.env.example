# ═══════════════════════════════════════════════════════════
#  PteroStore API Server — Environment Variables
#  Copy file ini ke .env dan isi dengan nilai yang sesuai
# ═══════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/pterostore

# ─── Keamanan (WAJIB diganti di production!) ──────────────
# Secret untuk signing JWT token — gunakan string panjang & acak
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_ini_dengan_string_acak_panjang_minimal_64_karakter

# ─── Admin Account ────────────────────────────────────────
# Dibuat otomatis saat server pertama kali jalan
ADMIN_EMAIL=admin@pterostore.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=aldev123

# ─── CORS ─────────────────────────────────────────────────
# Domain frontend yang diizinkan mengakses API
# Pisahkan dengan koma untuk multiple domain
# Gunakan * untuk izinkan semua (tidak disarankan di production)
ALLOWED_ORIGINS=*

# ─── SMTP (opsional — untuk OTP email) ───────────────────
# SMTP_USER=your@email.com
# SMTP_PASS=your_smtp_password
