# ═══════════════════════════════════════════════════════════
#  PteroStore Frontend — Environment Variables
#  Copy file ini ke .env dan isi dengan nilai yang sesuai
# ═══════════════════════════════════════════════════════════

# ─── API URL ──────────────────────────────────────────────
# URL ke API server PteroStore
# - Di Replit: KOSONGKAN (pakai proxy Replit otomatis)
# - Di hosting lain: isi dengan URL API server kamu
# Contoh: VITE_API_URL=https://api.pterostore.com
# Contoh: VITE_API_URL=http://localhost:8080 (local development)
VITE_API_URL=

# ─── Port (opsional) ──────────────────────────────────────
# Port untuk dev server (default: 3000)
# PORT=3000

# ─── Base Path (opsional) ─────────────────────────────────
# Base URL prefix jika app di-deploy di sub-path
# Contoh: BASE_PATH=/app
# Di Replit: diset otomatis
# BASE_PATH=/
